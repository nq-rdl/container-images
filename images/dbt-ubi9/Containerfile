# syntax=docker/dockerfile:1.7
#
# dbt-core on UBI9-micro
# Blueprint: dbt-labs/dbt-core docker/Dockerfile
# Changes: base image swap (python:slim-bullseye -> UBI9), install runtime
#          packages into a UBI-micro rootfs, venv-based install
#

# --- Build: compile dbt and native extensions ---
FROM registry.access.redhat.com/ubi9/ubi-minimal:9.5@sha256:a50731d3397a4ee28583f1699842183d4d24fadcc565c4688487af9ee4e13a44 AS builder

ARG DBT_VERSION=1.11.11
ARG DBT_ADAPTER=dbt-postgres
ARG PYTHON_VERSION=3.11

RUN microdnf install -y --nodocs \
        python${PYTHON_VERSION} \
        python${PYTHON_VERSION}-pip \
        python${PYTHON_VERSION}-devel \
        gcc \
        libpq-devel \
    && microdnf clean all \
    && rm -rf /var/cache/yum /var/cache/dnf

# hadolint ignore=DL3013
RUN python${PYTHON_VERSION} -m venv /opt/dbt \
    && /opt/dbt/bin/pip install --no-cache-dir --upgrade pip setuptools wheel \
    && /opt/dbt/bin/pip install --no-cache-dir \
        "dbt-core==${DBT_VERSION}" \
        ${DBT_ADAPTER:+"${DBT_ADAPTER}"}

# --- Runtime package rootfs ---
FROM registry.access.redhat.com/ubi9/ubi:9.5@sha256:d07a5e080b8a9b3624d3c9cfbfada9a6baacd8e6d4065118f0e80c71ad518044 AS runtime-rootfs

ARG PYTHON_VERSION=3.11

RUN mkdir -p /mnt/rootfs \
    && dnf install --installroot /mnt/rootfs --releasever 9 --setopt install_weak_deps=False --nodocs -y \
        python${PYTHON_VERSION} \
        libpq \
        git-core \
        openssh-clients \
    && dnf --installroot /mnt/rootfs clean all \
    && rm -rf /mnt/rootfs/var/cache/yum /mnt/rootfs/var/cache/dnf \
    && mkdir -p /mnt/rootfs/home/dbt \
    && chown 1001:0 /mnt/rootfs/home/dbt \
    && echo 'dbt:x:1001:0:dbt user:/home/dbt:/sbin/nologin' >> /mnt/rootfs/etc/passwd

# --- Runtime ---
FROM registry.access.redhat.com/ubi9/ubi-micro:9.5@sha256:839f16991579b023d4452eadd0efa925e438f8b73063afe4f75bdc6cf7a09b12

ARG DBT_VERSION=1.11.11
ARG PYTHON_VERSION=3.11

LABEL org.opencontainers.image.title="dbt-ubi9"
LABEL org.opencontainers.image.description="dbt-core ${DBT_VERSION} with Python ${PYTHON_VERSION} on UBI9 micro"
LABEL org.opencontainers.image.source="https://github.com/nq-rdl/container-images"
LABEL org.opencontainers.image.vendor="Research Data Laboratory"
LABEL org.opencontainers.image.licenses="Apache-2.0"

COPY --from=runtime-rootfs /mnt/rootfs/ /
COPY --from=builder /opt/dbt /opt/dbt

ENV PYTHONIOENCODING=utf-8
ENV LANG=C.UTF-8
ENV PYTHONDONTWRITEBYTECODE=1
ENV PATH="/opt/dbt/bin:${PATH}"

USER 1001
WORKDIR /home/dbt

HEALTHCHECK CMD dbt --version || exit 1

ENTRYPOINT ["dbt"]
CMD ["--version"]
