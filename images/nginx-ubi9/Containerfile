# syntax=docker/dockerfile:1.7
#
# nginx (UBI9 AppStream) static-file / SPA web server on UBI9-micro
# Blueprint: nginxinc/nginx-unprivileged; rdl-portal frontend/Dockerfile runtime stage + nginx.conf
# Changes: base swap (alpine -> UBI9), install nginx into a UBI-micro rootfs via dnf --installroot
#          (the dbt-ubi9 idiom), non-root uid 1001 on :8080, generic SPA config
#

# Single source of truth for the nginx version. NGINX_STREAM selects the UBI9 AppStream module
# stream; NGINX_VERSION is the exact patch the build asserts it actually installed, so the OCI
# label and image.yaml tags can't silently drift from the package if the stream advances.
ARG NGINX_STREAM=1.26
ARG NGINX_VERSION=1.26.3

# --- Runtime package rootfs: install nginx into a clean rootfs ---
FROM registry.access.redhat.com/ubi9/ubi:9.5@sha256:d07a5e080b8a9b3624d3c9cfbfada9a6baacd8e6d4065118f0e80c71ad518044 AS runtime-rootfs

# nginx is a modular package in UBI9 (streams 1.22/1.24/1.26); module state is per-rootfs, so the
# stream is enabled inside the target rootfs before install. nginx runs rootless (pid + temp paths
# under /tmp via nginx.conf), so no package cache dirs need chown here.
#
# The two log symlinks route nginx's compiled-in default log paths to the container's
# stdout/stderr: nginx opens them before it parses nginx.conf, so without the symlinks a non-root
# master logs a "could not open error log file" alert at startup.
ARG NGINX_STREAM
ARG NGINX_VERSION

RUN mkdir -p /mnt/rootfs \
    && dnf -y --installroot /mnt/rootfs --releasever 9 module enable "nginx:${NGINX_STREAM}" \
    && dnf -y --installroot /mnt/rootfs --releasever 9 --setopt install_weak_deps=False --nodocs install \
        nginx \
    && installed_ver="$(rpm -q --root /mnt/rootfs --queryformat '%{VERSION}' nginx)" \
    && { [ "${installed_ver}" = "${NGINX_VERSION}" ] || { echo "ERROR: installed nginx ${installed_ver} != declared NGINX_VERSION ${NGINX_VERSION}" >&2; exit 1; }; } \
    && dnf --installroot /mnt/rootfs clean all \
    && rm -rf /mnt/rootfs/var/cache/yum /mnt/rootfs/var/cache/dnf \
    && echo 'nginx-app:x:1001:0:nginx user:/usr/share/nginx:/sbin/nologin' >> /mnt/rootfs/etc/passwd \
    && mkdir -p /mnt/rootfs/usr/share/nginx/html /mnt/rootfs/var/log/nginx \
    && ln -sf /dev/stdout /mnt/rootfs/var/log/nginx/access.log \
    && ln -sf /dev/stderr /mnt/rootfs/var/log/nginx/error.log

# --- Runtime ---
FROM registry.access.redhat.com/ubi9/ubi-micro:9.5@sha256:839f16991579b023d4452eadd0efa925e438f8b73063afe4f75bdc6cf7a09b12

ARG NGINX_VERSION

LABEL org.opencontainers.image.title="nginx-ubi9"
LABEL org.opencontainers.image.description="nginx ${NGINX_VERSION} static-file/SPA web server on UBI9 micro (non-root, :8080)"
LABEL org.opencontainers.image.source="https://github.com/nq-rdl/container-images"
LABEL org.opencontainers.image.vendor="Research Data Laboratory"
LABEL org.opencontainers.image.licenses="BSD-2-Clause"

COPY --from=runtime-rootfs /mnt/rootfs/ /
# Rootless main config (pid + temp paths under /tmp) and a generic SPA server on :8080.
COPY nginx.conf /etc/nginx/nginx.conf
COPY default.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
USER 1001
WORKDIR /usr/share/nginx/html

# nginx shuts down gracefully on SIGQUIT (SIGTERM is a fast shutdown).
STOPSIGNAL SIGQUIT

ENTRYPOINT ["nginx"]
CMD ["-g", "daemon off;"]
